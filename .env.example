# MongoDB
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=idata-dev

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Google OAuth
GOOGLE_CREDENTIALS_PATH=data/credentials.json
GOOGLE_TOKEN_PATH=data/token.json

# Schedule (24h format, Asia/Kolkata)
TIMEZONE=Asia/Kolkata
MORNING_SCAN_TIME=07:00
EVENING_SCAN_TIME=19:00

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_HOST=http://ollama:11434
CLOUD_LLM_FALLBACK=false
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO
